{
    "name": "@goodbyenjn/configs",
    "version": "6.1.4",
    "description": "GoodbyeNJN's configs, including eslint, prettier, and more.",
    "keywords": [
        "eslint",
        "eslintconfig",
        "prettier",
        "prettierconfig",
        "typescript",
        "tsconfig"
    ],
    "homepage": "https://github.com/GoodbyeNJN/configs",
    "bugs": {
        "url": "https://github.com/GoodbyeNJN/configs/issues"
    },
    "license": "MIT",
    "author": "GoodbyeNJN <cc@fuckwall.cc>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/GoodbyeNJN/configs.git"
    },
    "type": "module",
    "exports": {
        "./eslint": {
            "types": "./dist/eslint/index.d.ts",
            "import": "./dist/eslint/index.js"
        },
        "./prettier": {
            "types": "./dist/prettier/index.d.ts",
            "import": "./dist/prettier/index.js"
        },
        "./tsconfigs/*": "./tsconfigs/*.json"
    },
    "files": [
        "dist",
        "tsconfigs"
    ],
    "scripts": {
        "build": "rolldown -c",
        "test": "vitest",
        "test:ci": "vitest run"
    },
    "devDependencies": {
        "@antfu/eslint-define-config": "1.23.0-2",
        "@goodbyenjn/configs": "file:",
        "@goodbyenjn/utils": "^26.4.4",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "8.58.2",
        "@typescript-eslint/parser": "8.58.2",
        "eslint": "^10.2.0",
        "eslint-config-alloy": "5.1.2",
        "eslint-config-flat-gitignore": "2.3.0",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "5.2.0",
        "find-up-simple": "^1.0.1",
        "globals": "17.5.0",
        "local-pkg": "1.1.2",
        "prettier": "^3.8.3",
        "rolldown": "1.0.0-rc.16",
        "rolldown-plugin-dts": "^0.23.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.4"
    },
    "peerDependencies": {
        "eslint": "^10.2.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3"
    },
    "napi": {
        "binaryName": "resolver",
        "packageName": "@unrs/resolver-binding",
        "wasm": {
            "browser": {
                "fs": true
            }
        },
        "targets": [
            "x86_64-pc-windows-msvc",
            "aarch64-pc-windows-msvc",
            "i686-pc-windows-msvc",
            "x86_64-unknown-linux-gnu",
            "x86_64-unknown-linux-musl",
            "x86_64-unknown-freebsd",
            "aarch64-unknown-linux-gnu",
            "aarch64-unknown-linux-musl",
            "armv7-unknown-linux-gnueabihf",
            "armv7-unknown-linux-musleabihf",
            "powerpc64le-unknown-linux-gnu",
            "riscv64gc-unknown-linux-gnu",
            "riscv64gc-unknown-linux-musl",
            "s390x-unknown-linux-gnu",
            "x86_64-apple-darwin",
            "aarch64-apple-darwin",
            "wasm32-wasip1-threads"
        ]
    },
    "optionalDependencies": {
        "@unrs/resolver-binding-darwin-arm64": "1.11.1",
        "@unrs/resolver-binding-darwin-x64": "1.11.1",
        "@unrs/resolver-binding-freebsd-x64": "1.11.1",
        "@unrs/resolver-binding-linux-arm-gnueabihf": "1.11.1",
        "@unrs/resolver-binding-linux-arm-musleabihf": "1.11.1",
        "@unrs/resolver-binding-linux-arm64-gnu": "1.11.1",
        "@unrs/resolver-binding-linux-arm64-musl": "1.11.1",
        "@unrs/resolver-binding-linux-ppc64-gnu": "1.11.1",
        "@unrs/resolver-binding-linux-riscv64-gnu": "1.11.1",
        "@unrs/resolver-binding-linux-riscv64-musl": "1.11.1",
        "@unrs/resolver-binding-linux-s390x-gnu": "1.11.1",
        "@unrs/resolver-binding-linux-x64-gnu": "1.11.1",
        "@unrs/resolver-binding-linux-x64-musl": "1.11.1",
        "@unrs/resolver-binding-wasm32-wasi": "1.11.1",
        "@unrs/resolver-binding-win32-arm64-msvc": "1.11.1",
        "@unrs/resolver-binding-win32-ia32-msvc": "1.11.1",
        "@unrs/resolver-binding-win32-x64-msvc": "1.11.1"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org",
        "access": "public"
    },
    "engines": {
        "node": ">=16"
    }
}
