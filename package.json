{
    "name": "@goodbyenjn/configs",
    "version": "6.3.0",
    "description": "GoodbyeNJN's configs, including oxlint, oxfmt, and tsconfig.",
    "keywords": [
        "oxfmt",
        "oxlint",
        "tsconfig"
    ],
    "homepage": "https://github.com/GoodbyeNJN/configs",
    "bugs": {
        "url": "https://github.com/GoodbyeNJN/configs/issues"
    },
    "license": "MIT",
    "author": "GoodbyeNJN <cc@fuckwall.cc>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/GoodbyeNJN/configs.git"
    },
    "files": [
        "dist",
        "tsconfigs"
    ],
    "type": "module",
    "exports": {
        "./oxlint": {
            "types": "./dist/oxlint/index.d.ts",
            "import": "./dist/oxlint/index.js"
        },
        "./oxfmt": {
            "types": "./dist/oxfmt/index.d.ts",
            "import": "./dist/oxfmt/index.js"
        },
        "./tsconfigs/*": "./tsconfigs/*.json"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    },
    "scripts": {
        "dev": "rolldown -w -c",
        "build": "rolldown -c",
        "check": "tsc && oxlint && oxfmt --check .",
        "typecheck": "tsc",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "format": "oxfmt --write .",
        "test": "vitest",
        "test:ci": "vitest --run"
    },
    "devDependencies": {
        "@goodbyenjn/utils": "^26.4.7",
        "@types/node": "^25.6.2",
        "find-up-simple": "1.0.1",
        "oxfmt": "^0.49.0",
        "oxlint": "^1.64.0",
        "oxlint-tsgolint": "^0.22.1",
        "rolldown": "^1.0.0",
        "rolldown-plugin-dts": "^0.25.0",
        "typescript": "^6.0.3",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.5"
    },
    "peerDependencies": {
        "oxfmt": "^0.40.0",
        "oxlint": "^1.60.0",
        "typescript": "^6.0.0"
    },
    "engines": {
        "node": ">=16"
    }
}
