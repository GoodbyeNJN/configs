{
    "name": "@goodbyenjn/configs",
    "version": "6.2.0",
    "description": "GoodbyeNJN's configs, including eslint, prettier, and more.",
    "keywords": [
        "eslint",
        "eslintconfig",
        "prettier",
        "prettierconfig",
        "typescript",
        "tsconfig"
    ],
    "homepage": "https://github.com/GoodbyeNJN/configs",
    "bugs": {
        "url": "https://github.com/GoodbyeNJN/configs/issues"
    },
    "license": "MIT",
    "author": "GoodbyeNJN <cc@fuckwall.cc>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/GoodbyeNJN/configs.git"
    },
    "type": "module",
    "exports": {
        "./eslint": {
            "types": "./dist/eslint/index.d.ts",
            "import": "./dist/eslint/index.js"
        },
        "./prettier": {
            "types": "./dist/prettier/index.d.ts",
            "import": "./dist/prettier/index.js"
        },
        "./tsconfigs/*": "./tsconfigs/*.json"
    },
    "files": [
        "dist",
        "tsconfigs"
    ],
    "scripts": {
        "dev": "rolldown -w -c",
        "build": "rolldown -c",
        "check": "tsc && eslint && prettier --check .",
        "typecheck": "tsc",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write .",
        "test": "vitest",
        "test:ci": "vitest --run"
    },
    "dependencies": {
        "@unrs/resolver-binding-wasm32-wasi": "1.11.1"
    },
    "devDependencies": {
        "@eslint-react/eslint-plugin": "5.7.5",
        "@eslint/js": "10.0.1",
        "@goodbyenjn/utils": "^26.4.7",
        "@types/micromatch": "^4.0.10",
        "@types/node": "^25.6.2",
        "@typescript-eslint/eslint-plugin": "8.59.2",
        "@typescript-eslint/parser": "8.59.2",
        "eslint": "^10.3.0",
        "eslint-plugin-import-x": "4.16.2",
        "eslint-typegen": "^2.3.1",
        "find-up-simple": "1.0.1",
        "globals": "17.6.0",
        "ignore": "^7.0.5",
        "memfs": "^4.57.2",
        "micromatch": "^4.0.8",
        "minimatch": "10.2.5",
        "mlly": "1.8.2",
        "prettier": "^3.8.3",
        "rolldown": "^1.0.0",
        "rolldown-plugin-dts": "^0.25.0",
        "typescript": "^6.0.3",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.5"
    },
    "peerDependencies": {
        "eslint": "^10.0.0",
        "prettier": "^3.0.0",
        "typescript": "^6.0.0"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org",
        "access": "public"
    },
    "engines": {
        "node": ">=16"
    }
}
