{
    "extends": "./tsconfigs/base.json",
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"],
            "@/types/*": ["./types/generated/*"]
        }
    },
    "include": ["./*", "src", "types", "tests", "scripts"],
    "exclude": ["tests/__fixtures__", "tests/__snapshots__"]
}
